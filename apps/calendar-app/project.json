{
  "name": "calendar-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "sc",
  "tags": ["scope:app", "type:app"],
  "sourceRoot": "apps/calendar-app/src",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/calendar-app",
        "index": "apps/calendar-app/src/index.html",
        "browser": "apps/calendar-app/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/calendar-app/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/calendar-app/public"
          }
        ],
        "styles": ["apps/calendar-app/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "16kb"
            }
          ],
          "outputHashing": "all",
          "optimization": true,
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "calendar-app:build:production"
        },
        "development": {
          "buildTarget": "calendar-app:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "port": 4200,
        "open": false
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "calendar-app:build"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/calendar-app/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/calendar-app/**/*.ts",
          "apps/calendar-app/**/*.html"
        ]
      }
    }
  }
}
